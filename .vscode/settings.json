{
	"editor.tabSize": 2,
	"editor.detectIndentation": false,
	"search.exclude": {
		"package-lock.json": true
	},
	"editor.defaultFormatter": "esbenp.prettier-vscode",
	"editor.codeActionsOnSave": {
		"source.fixAll.eslint": "explicit",
		"source.addMissingImports": "explicit"
	},
	"[prisma]": {
		"editor.defaultFormatter": "Prisma.prisma"
	},
	"files.associations": {
		"*.scss": "postcss"
	},
	"workbench.colorCustomizations": {
    "activityBar.activeBackground": "#779503",
    "activityBar.background": "#779503",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#63dcfc",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#779503",
    "statusBar.background": "#4f6302",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#779503",
    "statusBarItem.remoteBackground": "#4f6302",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#4f6302",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#4f630299",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
	"peacock.color": "#4f6302",
	"[dockerfile]": {
		"editor.defaultFormatter": "ms-azuretools.vscode-containers"
  },
  "prisma.pinToPrisma6": true
}
